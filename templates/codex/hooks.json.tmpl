{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "auto check --status --quiet",
        "timeout": 10
      }
    ]{{if or .Hooks.PreCommitArch .Hooks.PreCommitLore}},
    "PreToolUse": [
      {{if .Hooks.PreCommitArch}}{
        "matcher": "Bash",
        "type": "command",
        "command": "auto check --arch --quiet --warn-only",
        "timeout": 30
      }{{end}}{{if and .Hooks.PreCommitArch .Hooks.PreCommitLore}},{{end}}
      {{if .Hooks.PreCommitLore}}{
        "matcher": "Bash",
        "type": "command",
        "command": "auto check --lore --quiet",
        "timeout": 30
      }{{end}}
    ]{{end}}{{if or .Hooks.ReactCIFailure .Hooks.ReactReview}},
    "PostToolUse": [
      {
        "matcher": "Bash",
        "type": "command",
        "command": "auto react check --quiet",
        "timeout": 60
      }
    ]{{end}},
    "Stop": [
      {
        "type": "command",
        "command": "auto session save --quiet",
        "timeout": 10
      }
    ]
  }
}
