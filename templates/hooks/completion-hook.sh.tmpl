#!/bin/bash
# Autopus provider completion hook template.
# Sends a cmux signal when the provider finishes responding.
#
# Usage: This hook is triggered by the provider's CLI after response completion.
# The signal name follows the format: done-{provider} or done-{provider}-round{N}
#
# Environment variables:
#   AUTOPUS_PROVIDER - Provider name (claude, gemini, codex)
#   AUTOPUS_ROUND    - Current debate round number (default: 1)

PROVIDER="${AUTOPUS_PROVIDER:-{{.Provider}}}"
ROUND="${AUTOPUS_ROUND:-1}"

# Validate provider name: alphanumeric and hyphens only (prevent shell injection)
if ! echo "$PROVIDER" | grep -qE '^[a-zA-Z0-9][a-zA-Z0-9_-]*$'; then
    exit 0
fi
# Validate round is numeric
if ! echo "$ROUND" | grep -qE '^[0-9]+$'; then
    ROUND=1
fi

# Build signal name
if [ "$ROUND" -gt 1 ]; then
    SIGNAL="done-${PROVIDER}-round${ROUND}"
else
    SIGNAL="done-${PROVIDER}"
fi

# Send completion signal via cmux wait-for -S
if command -v cmux &>/dev/null; then
    cmux wait-for -S "$SIGNAL" 2>/dev/null || true
fi
