{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "auto check --arch --quiet --warn-only",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Agent",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TeamCreate",
      "SendMessage",
      "ToolSearch",
      "WebSearch",
      "mcp__sequential-thinking__sequentialthinking",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go mod:*)",
      "Bash(go tool:*)",
      "Bash(go env:*)",
      "Bash(go install:*)",
      "Bash(go clean:*)",
      "Bash(go get:*)",
      "Bash(go version:*)",
      "Bash(golangci-lint:*)",
      "Bash(gofmt:*)",
      "Bash(git:*)",
      "Bash(auto:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(gh:*)",
      "Bash(auto *)",
      "Bash(git *)",
      "Bash(make:*)"
    ]
  },
  "statusLine": {
    "command": ".claude/statusline.sh",
    "padding": 1,
    "type": "command"
  }
}
